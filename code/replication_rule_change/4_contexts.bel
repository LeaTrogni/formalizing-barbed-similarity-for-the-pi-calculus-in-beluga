%%% Properties of pairs of contexts %%%

% PCtx is symmetric
rec PCtx_symm: (g:ctx) (g':ctx) 
    PCtx [g' ⊢ P ] [g ⊢ CP ] [g' ⊢ Q] [g ⊢ CQ] -> PCtx [g' ⊢ Q ] [g ⊢ CQ ] [g' ⊢ P] [g ⊢ CP] =
  / total d (PCtx_symm _ _ _ _ _ _ d) /
  fn d => case d of 
  | pidM => pidM
  | pinM d' => let ih = PCtx_symm d' in pinM ih
  | poutM d' => let ih = PCtx_symm d' in poutM ih
  | pp1M d' => let ih = PCtx_symm d' in pp1M ih
  | pp2M d' => let ih = PCtx_symm d' in pp2M ih
  | presM d' => let ih = PCtx_symm d' in presM ih
  | prepM d' => let ih = PCtx_symm d' in prepM ih
;

% Given PCtx [g' |- P] [g |- CP] [g' |- R] [g |- CR], for each [g' |- Q] there exists some [g |- CQ] such that both PCtx [g' |- P] [g |- CP] [g' |- Q] [g |- CQ] and PCtx [g' |- Q] [g |- CQ] [g' |- R] [g |- CR] hold

% Auxiliary existence predicate
inductive Ex_ctx: (g':ctx) (g:ctx) [g' |- proc] -> [g |- proc] -> [g' |- proc] -> [g |- proc] -> [g' |- proc] -> ctype =
    | Ex_ctx_def: (g':ctx) (g:ctx)
        PCtx [g' |- P] [g |- CP] [g' |- Q] [g |- CQ] -> 
        PCtx [g' |- Q] [g |- CQ] [g' |- R] [g |- CR] -> 
        Ex_ctx [g' |- P] [g |- CP] [g' |- R] [g |- CR] [g' |- Q]
;

rec PCtx_trans: (g':ctx) (g:ctx) {Q:[g' |- proc]} PCtx [g' |- P] [g |- CP] [g' |- R] [g |- CR] 
  -> Ex_ctx [g' |- P] [g |- CP] [g' |- R] [g |- CR] [g' |- Q] =
    / total d (PCtx_trans _ _ _ _ _ _ _ d) /
    mlam Q => fn d => case d of
    | pidM => Ex_ctx_def pidM pidM
    | pinM d' => let Ex_ctx_def d1 d2 = PCtx_trans [_ |- Q] d' in Ex_ctx_def (pinM d1) (pinM d2)
    | poutM d' => let Ex_ctx_def d1 d2 = PCtx_trans [_ |- Q] d' in Ex_ctx_def (poutM d1) (poutM d2)
    | pp1M d' => let Ex_ctx_def d1 d2 = PCtx_trans [_ |- Q] d' in Ex_ctx_def (pp1M d1) (pp1M d2)
    | pp2M d' => let Ex_ctx_def d1 d2 = PCtx_trans [_ |- Q] d' in Ex_ctx_def (pp2M d1) (pp2M d2)
    | presM d' => let Ex_ctx_def d1 d2 = PCtx_trans [_ |- Q] d' in Ex_ctx_def (presM d1) (presM d2)
    | prepM d' => let Ex_ctx_def d1 d2 = PCtx_trans [_ |- Q] d' in Ex_ctx_def (prepM d1) (prepM d2)
;

% PCtx is functional
rec PCtx_funct: (g':ctx) (g:ctx) PCtx [g' |- P] [g |- CP] [g' |- P] [g |- CP'] -> [g |- eqp CP CP'] =
  / total d (PCtx_funct _ _ _ _ _ d) /
  fn d => case d of 
  | pidM => [_ |- refp]
  | pinM d' => let [_,x:names |- refp] = PCtx_funct d' in [_ |- refp]
  | poutM d' => let [_ |- refp] = PCtx_funct d' in [_ |- refp]
  | pp1M d' => let [_ |- refp] = PCtx_funct d' in [_ |- refp]
  | pp2M d' => let [_ |- refp] = PCtx_funct d' in [_ |- refp]
  | presM d' => let [_, x:names |- refp] = PCtx_funct d' in [_ |- refp]
  | prepM d' => let [_ |- refp] = PCtx_funct d' in [_ |- refp]
;

% PCtx is compositional
rec PCtx_comp: (g1:ctx) (g2:ctx) (g3:ctx) PCtx [g1 |- P] [g2 |- CP] [g1 |- Q] [g2 |- CQ] -> PCtx [g2 |- CP] [g3 |- CCP] [g2 |- CQ] [g3 |- CCQ] -> PCtx [g1 |- P] [g3 |- CCP] [g1 |- Q] [g3 |- CCQ] =
  / total d2 (PCtx_comp _ _ _ _ _ _ _ _ _ _ d2) /
  fn d1 => fn d2 => case d2 of
  | pidM => d1
  | pinM d' => pinM (PCtx_comp d1 d')
  | poutM d' => poutM (PCtx_comp d1 d')
  | pp1M d' => pp1M (PCtx_comp d1 d')
  | pp2M d' => pp2M (PCtx_comp d1 d')
  | presM d' => presM (PCtx_comp d1 d')
  | prepM d' => prepM (PCtx_comp d1 d')
;

% if Q has all the barbs of P, then C[Q] has all the barbs of C[Q]
rec PCtx_preserves_barb_in : (g:ctx) (g':ctx) ({Y : [g' |- names]} Barb_in [g' |- P] [g' |- Y] -> Barb_in [g' |- Q] [g' |- Y]) -> PCtx [g' |- P] [g |- CP] [g' |- Q] [g |- CQ] -> Barb_in [g |- CP] [g |- X] -> Barb_in [g |- CQ] [g |- X] =
  / total cp (PCtx_preserves_barb_in _ _ _ _ _ _ _ _ cp) /
  fn h => fn cp => fn b =>  let Barb_in_b s = b in case cp of 
  | pidM => h [_ |- _] b
  | pinM cp' => let [_ |- bs_in] = s in Barb_in_b [_ |- bs_in]
  | poutM cp' => impossible s
  | pp1M cp' => (case s of
    | [_ |- bs_par1 S] => let Barb_in_b [_ |- S'] = PCtx_preserves_barb_in h cp' (Barb_in_b [_ |- S]) in Barb_in_b [_ |- bs_par1 S']
    | [_ |- bs_par2 S] => Barb_in_b [_ |- bs_par2 S]
    )
  | pp2M cp' => (case s of
    | [_ |- bs_par1 S] => Barb_in_b [_ |- bs_par1 S]
    | [_ |- bs_par2 S] => let Barb_in_b [_ |- S'] = PCtx_preserves_barb_in h cp' (Barb_in_b [_ |- S]) in Barb_in_b [_ |- bs_par2 S']
    )
  | presM cp' => let [_ |- bs_res \x. S] = s in let Barb_in_b [_,x:names |- S'] = PCtx_preserves_barb_in h cp' (Barb_in_b [_,x:names |- S]) in Barb_in_b [_ |- bs_res \x. S']
  | prepM cp' => let [_ |- bs_rep S] = s in let Barb_in_b [_ |- S'] = PCtx_preserves_barb_in h cp' (Barb_in_b [_ |- S]) in Barb_in_b [_ |- bs_rep S']
;

rec PCtx_preserves_barb_out : (g:ctx) (g':ctx) ({Y : [g' |- names]} Barb_out [g' |- P] [g' |- Y] -> Barb_out [g' |- Q] [g' |- Y]) -> PCtx [g' |- P] [g |- CP] [g' |- Q] [g |- CQ] -> Barb_out [g |- CP] [g |- X] -> Barb_out [g |- CQ] [g |- X] =
  / total cp (PCtx_preserves_barb_out _ _ _ _ _ _ _ _ cp) /
  fn h => fn cp => fn b => case cp of 
  | pidM => h [_ |- _] b
  | pinM cp' => (case b of
    | Barb_out_f s => impossible s
    | Barb_out_b s => impossible s
    )
  | poutM cp' => (case b of
    | Barb_out_f s => let [_ |- fs_out] = s in Barb_out_f [_ |- fs_out]
    | Barb_out_b s => impossible s
    )
  | pp1M cp' => (case b of
    | Barb_out_f s => (case s of
      | [_ |- fs_par1 S] => let ih = PCtx_preserves_barb_out h cp' (Barb_out_f [_ |- S]) in (case ih of
        | Barb_out_f [_ |- S'] => Barb_out_f [_ |- fs_par1 S']
        | Barb_out_b [_ |- S'] => Barb_out_b [_ |- bs_par1 S']
        )
      | [_ |- fs_par2 S] => Barb_out_f [_ |- fs_par2 S]
      )
    | Barb_out_b s => (case s of
      | [_ |- bs_par1 S] => let ih = PCtx_preserves_barb_out h cp' (Barb_out_b [_ |- S]) in (case ih of
        | Barb_out_f [_ |- S'] => Barb_out_f [_ |- fs_par1 S']
        | Barb_out_b [_ |- S'] => Barb_out_b [_ |- bs_par1 S']
        )
      | [_ |- bs_par2 S] => Barb_out_b [_ |- bs_par2 S]
      )
    ) 
  | pp2M cp' => (case b of
    | Barb_out_f s => (case s of
      | [_ |- fs_par2 S] => let ih = PCtx_preserves_barb_out h cp' (Barb_out_f [_ |- S]) in (case ih of
        | Barb_out_f [_ |- S'] => Barb_out_f [_ |- fs_par2 S']
        | Barb_out_b [_ |- S'] => Barb_out_b [_ |- bs_par2 S']
        )
      | [_ |- fs_par1 S] => Barb_out_f [_ |- fs_par1 S]
      )
    | Barb_out_b s => (case s of
      | [_ |- bs_par2 S] => let ih = PCtx_preserves_barb_out h cp' (Barb_out_b [_ |- S]) in (case ih of
        | Barb_out_f [_ |- S'] => Barb_out_f [_ |- fs_par2 S']
        | Barb_out_b [_ |- S'] => Barb_out_b [_ |- bs_par2 S']
        )
      | [_ |- bs_par1 S] => Barb_out_b [_ |- bs_par1 S]
      )
    ) 
  | presM cp' => (case b of
    | Barb_out_f s => let [_ |- fs_res \x. S] = s in let ih = PCtx_preserves_barb_out h cp' (Barb_out_f [_,x:names |- S]) in (case ih of
        | Barb_out_f [_,x:names |- S'] => let ro = res_or_open [_ |- _] [_,x:names |- _] [_,x:names |- S'] in (case ro of
          | SameName s' => Barb_out_b s'
          | DiffName s' => Barb_out_f s'
        )
        | Barb_out_b [_,x:names |- S'] => Barb_out_b [_ |- bs_res \x. S']
        )
    | Barb_out_b s => (case s of
      | [_ |- bs_res \x. S] => let ih = PCtx_preserves_barb_out h cp' (Barb_out_b [_,x:names |- S]) in (case ih of
        | Barb_out_f [_,x:names |- S'] => let ro = res_or_open [_ |- _] [_,x:names |- _] [_,x:names |- S'] in (case ro of
          | SameName s' => Barb_out_b s'
          | DiffName s' => Barb_out_f s'
        )
        | Barb_out_b [_,x:names |- S'] => Barb_out_b [_ |- bs_res \x. S']
        )
      | [_ |- bs_open \x. S] => let ih = PCtx_preserves_barb_out h cp' (Barb_out_f [_,x:names |- S]) in (case ih of
        | Barb_out_f [_,x:names |- S'] => let ro = res_or_open [_ |- _] [_,x:names |- _] [_,x:names |- S'] in (case ro of
          | SameName s' => Barb_out_b s'
          | DiffName s' => Barb_out_f s'
        )
        | Barb_out_b [_,x:names |- S'] => Barb_out_b [_ |- bs_res \x. S']
        )
      )
    )
  | prepM cp' => (case b of
    | Barb_out_f s => let [_ |- fs_rep S] = s in let ih = PCtx_preserves_barb_out h cp' (Barb_out_f [_ |- S]) in (case ih of
        | Barb_out_f [_ |- S'] => Barb_out_f [_ |- fs_rep S']
        | Barb_out_b [_ |- S'] => Barb_out_b [_ |- bs_rep S']
        )
    | Barb_out_b s => let [_ |- bs_rep S] = s in let ih = PCtx_preserves_barb_out h cp' (Barb_out_b [_ |- S]) in (case ih of
        | Barb_out_f [_ |- S'] => Barb_out_f [_ |- fs_rep S']
        | Barb_out_b [_ |- S'] => Barb_out_b [_ |- bs_rep S']
        )
    )
;

